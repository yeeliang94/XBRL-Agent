# SOFP Agent Web UI Configuration
# Copy this file to .env and fill in your values
#
# Get LLM_PROXY_URL and GOOGLE_API_KEY from:
#   Bruno -> Collection -> Auth tab -> Vars/Secrets

# --- Mac (direct Gemini API) ---
# Leave LLM_PROXY_URL empty and set GEMINI_API_KEY
LLM_PROXY_URL=
GEMINI_API_KEY=

# --- Windows (enterprise proxy) ---
# Set LLM_PROXY_URL and GOOGLE_API_KEY (from Bruno -> Collection -> Auth tab)
# LLM_PROXY_URL=https://genai-sharedservice-emea.pwc.com
# GOOGLE_API_KEY=sk-xxx

# Optional: OpenAI API key (for direct OpenAI model usage, e.g. gpt-5.4)
OPENAI_API_KEY=

# Optional: Anthropic API key (for direct Claude model usage, e.g. claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Model name as registered on the proxy
# Do NOT use google-gla: prefix -- the proxy speaks OpenAI protocol
TEST_MODEL=vertex_ai.gemini-3-flash-preview

# WARNING: Do not set temperature below 1.0 for Gemini 3 models -- causes failures

# Optional: Override the scout agent model (default: google-gla:gemini-3-flash-preview)
# Available models: gemini-3-flash-preview, gemini-2.5-flash, gemini-2.5-pro,
#   gemini-3.1-pro-preview, gemini-3.1-flash-lite-preview
# On Mac (direct API): prefix with google-gla:  e.g. google-gla:gemini-3-flash-preview
# On Windows (proxy):  use proxy name  e.g. vertex_ai.gemini-3-flash-preview
SCOUT_MODEL=

# Server host and port
HOST=0.0.0.0
PORT=8002
