# SOFP Agent Web UI Configuration
# Copy this file to .env and fill in your values
#
# Get LLM_PROXY_URL and GOOGLE_API_KEY from:
#   Bruno -> Collection -> Auth tab -> Vars/Secrets

# --- Mac (direct Gemini API) ---
# Leave LLM_PROXY_URL empty and set GEMINI_API_KEY
LLM_PROXY_URL=
GEMINI_API_KEY=

# --- Windows (enterprise proxy) ---
# Set LLM_PROXY_URL and GOOGLE_API_KEY (from Bruno -> Collection -> Auth tab)
# LLM_PROXY_URL=https://genai-sharedservice-emea.pwc.com
# GOOGLE_API_KEY=sk-xxx

# Optional: OpenAI API key (for direct OpenAI model usage, e.g. gpt-5.4)
OPENAI_API_KEY=

# Optional: Anthropic API key (for direct Claude model usage, e.g. claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Default model for all agents. Canonical id is `openai.gpt-5.4`, which
# server._create_proxy_model routes correctly on both platforms (direct
# OpenAI API on Mac, LiteLLM proxy on Windows).
TEST_MODEL=openai.gpt-5.4

# Other available ids (see config/models.json for the full list):
#   openai.gpt-5.4-mini, openai.gpt-5.4-nano        -- cheaper OpenAI tiers
#   bedrock.anthropic.claude-sonnet-4-6             -- Anthropic
#   vertex_ai.gemini-3-flash-preview                -- Gemini (proxy)
#   google-gla:gemini-3-flash-preview               -- Gemini (Mac direct)

# WARNING: Do not set temperature below 1.0 for Gemini 3 models -- causes failures

# Scout agent model. Defaults to openai.gpt-5.4 — the scout's observations
# (variants, page mappings, note-section detection) flow into every downstream
# agent as advisory hints, so we keep it on the flagship tier for coverage and
# quality. Set to openai.gpt-5.4-mini / -nano to trade quality for cost.
# Blank = fall back to TEST_MODEL.
SCOUT_MODEL=openai.gpt-5.4

# Server host and port
# Loopback by default. The app now has an auth layer (every /api/* route is
# gated), but HOST=0.0.0.0 still exposes the login form to the whole network —
# only set it on a trusted LAN or behind Azure App Service.
HOST=127.0.0.1
PORT=8002

# --- Authentication (PLAN-azure-auth-deployment Phase 1) ---
# Email + password login. Accounts are provisioned with the admin CLI:
#   python -m auth.manage add-user you@firm.com --name "Your Name"
#
# AUTH_MODE: leave UNSET for the real password login (default, used in prod and
# the normal local experience). Set to `dev` ONLY for CI / fully-offline work —
# it auto-sessions as dev@localhost with no login form. A startup guard refuses
# to boot in dev mode on Azure (WEBSITE_SITE_NAME present), so it can never ship
# to production.
# AUTH_MODE=dev
#
# Auto-provision a REAL admin account at server startup (start.bat / start.sh)
# so local devs get a working email+password login without the admin
# `python -m auth.manage` CLI step. Opt-in: BOTH vars must be set. Idempotent and
# non-destructive — on reboot it only ensures the admin role, never resets a
# password you've since changed. Uncomment + set a password (>= 8 chars) below.
#   SECURITY: these are LOCAL-DEV creds. Do NOT carry this .env to a shared /
#   Azure box — a known admin password there is a wide-open door. For prod,
#   leave these unset and provision with `python -m auth.manage add-user`.
# BOOTSTRAP_ADMIN_EMAIL=admin@localhost
# BOOTSTRAP_ADMIN_PASSWORD=changeme-local-dev
# BOOTSTRAP_ADMIN_NAME=Local Admin
#
# SESSION_SECRET signs the session cookie. Local dev falls back to an insecure
# constant if unset; PRODUCTION REFUSES TO START without it. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
#
# Sliding idle timeout (seconds) before auto-logout. Default 900 (15 min).
# AUTH_IDLE_TIMEOUT_S=900
#
# Brute-force lockout: N failed logins per (email, IP) locks the pair for the
# window. Defaults: 5 attempts, 900s lockout.
# AUTH_LOGIN_MAX_ATTEMPTS=5
# AUTH_LOGIN_LOCKOUT_S=900
